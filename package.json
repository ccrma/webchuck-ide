        "@types/pako": "^2.0.4",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "eslint": "^10.2.1",
        "globals": "^17.5.0",
        "prettier": "3.8.3",
        "tailwindcss": "^4.2.2",
        "typescript": "^6.0.3",
        "vite": "^8.0.8"
    },
    "dependencies": {
        "@xterm/addon-fit": "^0.11.0",
